# Deployment target: development | preview | staging | production.
# Must be set AT BUILD TIME. Anything other than "production" is fully
# noindexed (robots, sitemap, meta and X-Robots-Tag). A deployed build
# without this variable is treated as "preview" and never indexed.
DEPLOYMENT_ENV=development

# Emit the Content-Security-Policy as report-only (staging rollout aid).
CSP_REPORT_ONLY=false

# Public site configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_MAP_URL=
NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# PostgreSQL
DATABASE_URL=postgresql://bti:bti_local_password@localhost:5432/bti_website?schema=public

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis REST or compatible Redis REST endpoint
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Lead delivery
ODOO_LEAD_WEBHOOK_URL=
ODOO_LEAD_WEBHOOK_SECRET=
GENERIC_LEAD_WEBHOOK_URL=
GENERIC_LEAD_WEBHOOK_SECRET=

# Internal operations
LEAD_RETRY_CRON_SECRET=
LEAD_HASH_SALT=

# Staff lead-admin (/admin) HTTP Basic auth. Required in production (password
# >= 12 chars). Without LEAD_ADMIN_PASSWORD set, the /admin area is blocked.
LEAD_ADMIN_USER=admin
LEAD_ADMIN_PASSWORD=

# Development-only bypasses. Each defaults to off, must be set to "true"
# explicitly, and is rejected by production environment validation.
# Never set these in a deployed environment.
ALLOW_DEV_SPAM_PROTECTION_BYPASS=false
ALLOW_DEV_TURNSTILE_BYPASS=false
ALLOW_DEV_LOCAL_RATE_LIMIT=false
