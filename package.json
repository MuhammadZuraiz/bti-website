{
  "name": "bti-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "lint:ts": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\" \"scripts/**/*.{ts,tsx}\" --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run",
    "build": "next build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:verify": "node scripts/verify-database.mjs",
    "test:webhook-server": "node scripts/test-webhook-server.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check:seo-headers": "node scripts/check-seo-headers.mjs",
    "leads:export": "node scripts/export-leads.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "lucide-react": "1.17.0",
    "next": "16.2.9",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.78.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
